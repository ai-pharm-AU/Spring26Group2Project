# PATHS
RAW_IMAGE_ZIP = "/content/drive/MyDrive/SKNCCR/MILK10k_Training_Input.zip"  # Path to your zip file
EXTRACT_DIR = "/content/MILK10k_Training_Input/" # Directory to extract images to
DIAG_CSV = "/content/drive/MyDrive/SKNCCR/MILK10k_Training_Supplement.csv"  # diagnosis CSV
OUTPUT_PATH = "/content/milk10k_cancer_binary/"

# Extract images from zip file
print(f"Extracting images from {RAW_IMAGE_ZIP} to {EXTRACT_DIR}...")
with zipfile.ZipFile(RAW_IMAGE_ZIP, 'r') as zip_ref:
    zip_ref.extractall(EXTRACT_DIR)
print("Extraction complete.")

# Update RAW_IMAGE_DIR to the extracted directory
RAW_IMAGE_DIR = EXTRACT_DIR

# BUILD IMAGE PATH MAPPING
image_id_to_path = {}
print("Building image path mapping...")
for root, _, files in os.walk(RAW_IMAGE_DIR):
    for file in files:
        if file.lower().endswith(('.png', '.jpg', '.jpeg')):
            isic_id = os.path.splitext(file)[0]
            image_id_to_path[isic_id] = os.path.join(root, file)
print(f"Found {len(image_id_to_path)} images.")

# CREATE FOLDER STRUCTURE
for c in ["cancer", "non_cancer"]:
    os.makedirs(os.path.join(OUTPUT_PATH, c), exist_ok=True)

# LOAD CSV
df = pd.read_csv(DIAG_CSV)
print("Columns:", df.columns.tolist())
print(df.head())

# Filter only images we actually have
df = df[df['isic_id'].isin(image_id_to_path.keys())].copy() # .copy() to avoid SettingWithCopyWarning
print(f"Filtered DataFrame size after matching images: {len(df)}")

# MAP LABELS
def map_label(row):
    diagnosis = str(row["diagnosis_full"]).lower()
    cancer_terms = ["melanoma", "squamous cell carcinoma", "basal cell carcinoma",
                    "actinic keratosis", "keratoacanthoma", "atypical fibroxanthoma",
                    "kaposi sarcoma", "malignant peripheral nerve sheath tumor",
                    "merkel cell carcinoma"]
    if any(term in diagnosis for term in cancer_terms):
        return "cancer"
    else:
        return "non_cancer"

df['label'] = df.apply(map_label, axis=1) # Assign the labels to a new 'label' column
print("Labels mapped.")
print(df['label'].value_counts()) # To see distribution

# COPY IMAGES TO FOLDER
print("Copying images to structured folders...")
for _, row in tqdm(df.iterrows(), total=len(df)):
    img_id = row["isic_id"]
    label = row["label"]
    src = image_id_to_path[img_id] # Use the pre-built mapping for source path
    dst = os.path.join(OUTPUT_PATH, label, img_id + ".jpg")
    shutil.copy(src, dst)
print("Image copying complete.")

# Verify
for root, dirs, files in os.walk(OUTPUT_PATH):
    print(root, len(files))

