import pandas as pd
import os
import shutil
from tqdm import tqdm
import tensorflow as tf
from tensorflow.keras.preprocessing.image import ImageDataGenerator
from tensorflow.keras.applications import EfficientNetB2
from tensorflow.keras import layers, models
import numpy as np
from sklearn.utils.class_weight import compute_class_weight
from datasets import load_dataset # Added for HuggingFace dataset
from PIL import Image # Added for saving HuggingFace images

# PATHS
RAW_IMAGE_DIR_1 = "/content/MILK10k_Training_Input/"  # folder with your images for first dataset
DIAG_CSV_1 = "/content/drive/MyDrive/SKNCCR/MILK10k_Training_Supplement.csv"  # diagnosis CSV for first dataset
OUTPUT_PATH = "/content/milk10k_cancer_binary/"
NEW_DATASET_DIR = "/content/africa_skin_cancer/" # Directory for the new dataset

# BUILD IMAGE PATH MAPPING - Dataset 1
image_id_to_path_1 = {}
print("Building image path mapping for Dataset 1...")
for root, _, files in os.walk(RAW_IMAGE_DIR_1):
    for file in files:
        if file.lower().endswith(('.png', '.jpg', '.jpeg')):
            isic_id = os.path.splitext(file)[0]
            image_id_to_path_1[isic_id] = os.path.join(root, file)
print(f"Found {len(image_id_to_path_1)} images in Dataset 1.")

# LOAD CSV - Dataset 1
df1 = pd.read_csv(DIAG_CSV_1)
print("Columns for Dataset 1:", df1.columns.tolist())
# Filter only images we actually have for Dataset 1
df1 = df1[df1['isic_id'].isin(image_id_to_path_1.keys())].copy()
print(f"Filtered DataFrame size for Dataset 1 after matching images: {len(df1)}")

# LOAD AND PROCESS DATASET 2 (Hugging Face EHR)
print("Loading and processing Dataset 2 from Hugging Face...")
# Create a directory to store images from the new dataset
os.makedirs(NEW_DATASET_DIR, exist_ok=True)

# Load the dataset from Hugging Face
dataset = load_dataset("electricsheepafrica/Africa-skin-cancer-images-EHR")

# Convert to pandas DataFrame for easier processing
df2_list = []
image_id_to_path_2 = {}
for i, item in enumerate(tqdm(dataset['train'])):
    # Assuming the image is directly accessible via 'image' feature
    # and diagnosis is in 'meta' -> 'lesion_type_diagnosis'
    img = item['image']
    diagnosis_raw = item['meta']['lesion_type_diagnosis']
    img_id = f"africa_img_{i:05d}" # Create a unique ID for each image

    # Save the image locally
    img_path = os.path.join(NEW_DATASET_DIR, f"{img_id}.jpg")
    img.save(img_path)

    image_id_to_path_2[img_id] = img_path
    df2_list.append({"isic_id": img_id, "diagnosis_full": diagnosis_raw})

df2 = pd.DataFrame(df2_list)
print(f"Found {len(image_id_to_path_2)} images in Dataset 2.")
print("Columns for Dataset 2:", df2.columns.tolist())
print(df2.head())


# COMBINE DATASETS
# Ensure consistent column names before concatenation
df1_renamed = df1[['isic_id', 'diagnosis_full']].copy()
df_combined = pd.concat([df1_renamed, df2[['isic_id', 'diagnosis_full']]], ignore_index=True)
image_id_to_path = {**image_id_to_path_1, **image_id_to_path_2} # Merge dictionaries

print(f"Combined DataFrame size: {len(df_combined)}")
print(f"Combined image path mapping size: {len(image_id_to_path)}")

# MAP LABELS
def map_label(row):
    diagnosis = str(row["diagnosis_full"]).lower()
    # Terms for Dataset 1
    cancer_terms_1 = ["melanoma", "squamous cell carcinoma", "basal cell carcinoma",
                      "actinic keratosis", "keratoacanthoma", "atypical fibroxanthoma",
                      "kaposi sarcoma", "malignant peripheral nerve sheath tumor",
                      "merkel cell carcinoma"]

    # Terms for Dataset 2 (mel, bcc, akiec)
    cancer_terms_2 = ["mel", "bcc", "akiec"]

    if any(term in diagnosis for term in cancer_terms_1) or \
       any(term in diagnosis for term in cancer_terms_2):
        return "cancer"
    else:
        return "non_cancer"

df_combined['label'] = df_combined.apply(map_label, axis=1) # Assign the labels to a new 'label' column
print("Labels mapped.")
print(df_combined['label'].value_counts()) # To see distribution

# CREATE FOLDER STRUCTURE 
for c in ["cancer", "non_cancer"]:
    os.makedirs(os.path.join(OUTPUT_PATH, c), exist_ok=True)

# COPY IMAGES TO FOLDER
print("Copying images to structured folders...")
# Clear the existing output path to avoid duplication if running multiple times
if os.path.exists(OUTPUT_PATH):
    shutil.rmtree(OUTPUT_PATH)
for c in ["cancer", "non_cancer"]:
    os.makedirs(os.path.join(OUTPUT_PATH, c), exist_ok=True)

for _, row in tqdm(df_combined.iterrows(), total=len(df_combined)):
    img_id = row["isic_id"]
    label = row["label"]
    src = image_id_to_path[img_id] # Use the combined mapping for source path
    dst = os.path.join(OUTPUT_PATH, label, img_id + ".jpg")
    shutil.copy(src, dst)
print("Image copying complete.")

# Verify
for root, dirs, files in os.walk(OUTPUT_PATH):
    print(f"Folder: {os.path.basename(root)}, Images: {len(files)}")

# DATA GENERATORS 
train_gen = ImageDataGenerator(
    rescale=1./255,
    validation_split=0.2,
    horizontal_flip=True,
    vertical_flip=True
)

train_data = train_gen.flow_from_directory(
    OUTPUT_PATH,
    target_size=(260,260),
    batch_size=32,
    class_mode='binary',
    subset='training'
)

val_data = train_gen.flow_from_directory(
    OUTPUT_PATH,
    target_size=(260,260),
    batch_size=32,
    class_mode='binary',
    subset='validation'
)

# CLASS WEIGHTS
# Recompute class weights based on the combined dataset
class_weights = compute_class_weight(
    class_weight='balanced',
    classes=np.unique(train_data.classes),
    y=train_data.classes
)
class_weights = dict(enumerate(class_weights))
print("Class weights:", class_weights)

# MODEL 
base_model = EfficientNetB2(
    weights='imagenet',
    include_top=False,
    input_shape=(260,260,3)
)

base_model.trainable = False

x = base_model.output
x = layers.GlobalAveragePooling2D()(x)
x = layers.Dense(512, activation='relu')(x)
x = layers.Dropout(0.3)(x)
output = layers.Dense(1, activation='sigmoid')(x)

model = models.Model(inputs=base_model.input, outputs=output)

# COMPILE 
optimizer = tf.keras.optimizers.Adam(
    learning_rate=1e-4,
    beta_1=0.9,
    beta_2=0.999,
    clipnorm=1.0
)

model.compile(
    optimizer=optimizer,
    loss='binary_crossentropy',
    metrics=['accuracy', tf.keras.metrics.AUC(name='auc')]
)

# CALLBACKS 
callbacks = [
    tf.keras.callbacks.ReduceLROnPlateau(
        monitor='val_auc',
        factor=0.5,
        patience=3,
        min_lr=1e-7,
        verbose=1
    ),
    tf.keras.callbacks.EarlyStopping(
        monitor='val_auc',
        patience=7,
        restore_best_weights=True,
        verbose=1
    ),
    tf.keras.callbacks.ModelCheckpoint(
        "best_model.h5",
        monitor='val_auc',
        save_best_only=True,
        verbose=1
    )
]



# TRAINING PHASE 1 (FROZEN)
history = model.fit(
    train_data,
    validation_data=val_data,
    epochs=50, # Changed from 1 to 50
    class_weight=class_weights, # <-- use manual weights here
    callbacks=callbacks
)
# TRAINING PHASE 2 (UNFREEZE)
base_model.trainable = True

model.compile(
    optimizer=tf.keras.optimizers.Adam(1e-5),
    loss='binary_crossentropy',
    metrics=['accuracy', tf.keras.metrics.AUC(name='auc')]
)

history = model.fit(
    train_data,
    validation_data=val_data,
    epochs=50, # Changed from 1 to 50
    class_weight=class_weights,
    callbacks=callbacks
)

# SAVE MODEL
model.save("ehrmodel.h5")
