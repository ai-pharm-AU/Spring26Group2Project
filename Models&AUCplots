plt.title('Model Accuracy')
plt.ylabel('Accuracy')
plt.xlabel('Epoch')
plt.legend(loc='upper left')
plt.xticks(range(len(history.history['accuracy'])), [f'Epoch {i+1}' for i in range(len(history.history['accuracy']))])
plt.grid(True)
