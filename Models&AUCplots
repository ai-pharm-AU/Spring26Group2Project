import tensorflow as tf
from tensorflow.keras.preprocessing import image
import numpy as np
import os
from PIL import Image

# Load the saved model
model = tf.keras.models.load_model('test_model.h5')
print("Model loaded successfully!")

# TEST SAMPLE IMAGE
OUTPUT_PATH = "/content/milk10k_cancer_binary/"

# Get a sample image path (e.g., from the 'cancer' class)
cancer_dir = os.path.join(OUTPUT_PATH, 'cancer')
sample_image_name = os.listdir(cancer_dir)[0] # Take the first image
sample_image_path = os.path.join(cancer_dir, sample_image_name)

print(f"Selected sample image: {sample_image_path}")

# Load and preprocess the image
img = Image.open(sample_image_path)
img = img.resize((260, 260)) # Resize to target size used during training
img_array = image.img_to_array(img)
img_array = np.expand_dims(img_array, axis=0) # Create a batch
img_array /= 255.0 # Rescale the image like during training

print(f"Preprocessed image shape: {img_array.shape}")

import matplotlib.pyplot as plt

# Plot training & validation accuracy values
plt.figure(figsize=(12, 6))
